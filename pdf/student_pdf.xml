<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Bind PDF report to university.student model (accessible from list and form views) -->
    <record id="action_report_student" model="ir.actions.report">
        <field name="name">Academic Report</field>
        <field name="model">university.student</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">university.report_student_template</field>
        <field name="report_file">university.report_student_template</field>
        <field name="print_report_name">'Report_%s' % (object.name.replace(' ', '_'))</field>
        <field name="binding_model_id" ref="model_university_student"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_student_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <!-- Note: inline styles are required in QWeb PDF templates (no external CSS support) -->
                    <div class="page" style="font-family: Arial, Helvetica, sans-serif; color: #2c3e50; font-size: 13px; line-height: 1.5;">

                        <!-- HEADER: University logo + document title -->
                        <table style="width: 100%; border-bottom: 3px solid #2d6cdf; margin-bottom: 24px; padding-bottom: 12px;">
                            <tr>
                                <td style="vertical-align: middle;">
                                    <div style="font-size: 26px; font-weight: bold; color: #2d6cdf; margin-bottom: 2px;">Academic Record</div>
                                    <div style="font-size: 13px; color: #7f8c8d;">Official student document</div>
                                </td>
                                <td style="text-align: right; vertical-align: middle; width: 180px;">
                                    <t t-if="o.university_id.image_1920">
                                        <img t-att-src="image_data_uri(o.university_id.image_1920)" style="max-height: 70px; max-width: 160px;"/>
                                    </t>
                                    <t t-else="">
                                        <div style="font-size: 16px; font-weight: bold; color: #7f8c8d;"><span t-field="o.university_id.name"/></div>
                                    </t>
                                </td>
                            </tr>
                        </table>

                        <!-- STUDENT INFO: Personal data and university/address -->
                        <table style="width: 100%; background-color: #f4f6f9; border: 1px solid #dce1e7; border-radius: 6px; margin-bottom: 28px;">
                            <tr>
                                <td style="padding: 16px 20px; width: 50%; border-right: 1px solid #dce1e7; vertical-align: top;">
                                    <div style="font-size: 10px; font-weight: bold; color: #7f8c8d; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px;">Student Information</div>
                                    <div style="font-size: 18px; font-weight: bold; color: #2c3e50; margin-bottom: 4px;"><span t-field="o.name"/></div>
                                    <div style="color: #555; margin-bottom: 4px;">
                                        <t t-if="o.email"><span t-field="o.email"/></t>
                                        <t t-else=""><span style="color: #aaa; font-style: italic;">No email on record</span></t>
                                    </div>
                                    <div style="margin-top: 8px; color: #555;">
                                        <strong>Tutor:</strong>
                                        <t t-if="o.tutor_id"> <span t-field="o.tutor_id.name"/></t>
                                        <t t-else=""><span style="color: #aaa; font-style: italic;"> Not assigned</span></t>
                                    </div>
                                </td>
                                <td style="padding: 16px 20px; vertical-align: top;">
                                    <div style="font-size: 10px; font-weight: bold; color: #7f8c8d; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px;">University &amp; Location</div>
                                    <div style="font-size: 15px; font-weight: bold; color: #2c3e50; margin-bottom: 4px;"><span t-field="o.university_id.name"/></div>
                                    <div style="color: #555;">
                                        <span t-field="o.street"/><br/>
                                        <span t-field="o.city"/>
                                        <t t-if="o.state_id">, <span t-field="o.state_id.name"/></t>
                                        <t t-if="o.zip_code"> <span t-field="o.zip_code"/></t>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <!-- SECTION 1: SUBJECT SUMMARY — average grade per enrollment -->
                        <div style="margin-bottom: 28px;">
                            <div style="display: flex; align-items: center; margin-bottom: 12px;">
                                <div style="background-color: #2d6cdf; color: white; border-radius: 4px; padding: 2px 10px; font-weight: bold; font-size: 15px; margin-right: 10px;">1</div>
                                <div style="font-size: 16px; font-weight: bold; color: #2c3e50;">Subject Summary</div>
                            </div>
                            <table style="width: 100%; border-collapse: collapse; border: 1px solid #dce1e7;">
                                <thead>
                                    <tr style="background-color: #eaf0fb;">
                                        <th style="padding: 10px 14px; text-align: left; font-size: 11px; text-transform: uppercase; color: #555; letter-spacing: 0.5px; border-bottom: 2px solid #2d6cdf; width: 40%;">Subject</th>
                                        <th style="padding: 10px 14px; text-align: left; font-size: 11px; text-transform: uppercase; color: #555; letter-spacing: 0.5px; border-bottom: 2px solid #2d6cdf; width: 40%;">Professor</th>
                                        <th style="padding: 10px 14px; text-align: center; font-size: 11px; text-transform: uppercase; color: #555; letter-spacing: 0.5px; border-bottom: 2px solid #2d6cdf; width: 20%;">Average Score</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="student_summaries.get(o.id, [])" t-as="summary">
                                        <tr style="border-bottom: 1px solid #eee;">
                                            <td style="padding: 10px 14px; font-weight: bold; color: #2c3e50;"><span t-out="summary['subject']"/></td>
                                            <td style="padding: 10px 14px; color: #555;"><span t-out="summary['professor']"/></td>
                                            <td style="padding: 10px 14px; text-align: center;">
                                                <t t-set="avg" t-value="summary['average']"/>
                                                <span t-attf-style="display: inline-block; padding: 3px 12px; border-radius: 12px; font-weight: bold; font-size: 13px; color: white; background-color: #{ '#27ae60' if avg >= 5.0 else '#e74c3c' };">
                                                    <span t-out="summary['average']" t-options='{"widget": "float", "precision": 2}'/>
                                                </span>
                                            </td>
                                        </tr>
                                    </t>
                                    <tr t-if="not student_summaries.get(o.id, [])">
                                        <td colspan="3" style="padding: 16px; text-align: center; color: #aaa; font-style: italic;">No subjects registered.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- SECTION 2: FULL EVALUATION HISTORY — every grade entry -->
                        <div style="margin-bottom: 28px;">
                            <div style="display: flex; align-items: center; margin-bottom: 12px;">
                                <div style="background-color: #2d6cdf; color: white; border-radius: 4px; padding: 2px 10px; font-weight: bold; font-size: 15px; margin-right: 10px;">2</div>
                                <div style="font-size: 16px; font-weight: bold; color: #2c3e50;">Evaluation History</div>
                            </div>
                            <table style="width: 100%; border-collapse: collapse; border: 1px solid #dce1e7;">
                                <thead>
                                    <tr style="background-color: #eaf0fb;">
                                        <th style="padding: 10px 14px; text-align: left; font-size: 11px; text-transform: uppercase; color: #555; border-bottom: 2px solid #2d6cdf; width: 18%;">Date</th>
                                        <th style="padding: 10px 14px; text-align: left; font-size: 11px; text-transform: uppercase; color: #555; border-bottom: 2px solid #2d6cdf; width: 35%;">Subject</th>
                                        <th style="padding: 10px 14px; text-align: left; font-size: 11px; text-transform: uppercase; color: #555; border-bottom: 2px solid #2d6cdf; width: 32%;">Professor</th>
                                        <th style="padding: 10px 14px; text-align: right; font-size: 11px; text-transform: uppercase; color: #555; border-bottom: 2px solid #2d6cdf; width: 15%;">Score</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.grade_ids" t-as="grade">
                                        <tr style="border-bottom: 1px solid #eee;">
                                            <td style="padding: 9px 14px; color: #555;"><span t-field="grade.date"/></td>
                                            <td style="padding: 9px 14px; color: #2c3e50;"><span t-field="grade.enrollment_id.subject_id.name"/></td>
                                            <td style="padding: 9px 14px; color: #555;"><span t-field="grade.enrollment_id.professor_id.name"/></td>
                                            <td style="padding: 9px 14px; text-align: right; font-weight: bold;">
                                                <t t-set="sc" t-value="grade.score"/>
                                                <span t-attf-style="color: #{ '#27ae60' if sc >= 5.0 else '#e74c3c' };"><span t-field="grade.score"/></span>
                                            </td>
                                        </tr>
                                    </t>
                                    <tr t-if="not o.grade_ids">
                                        <td colspan="4" style="padding: 16px; text-align: center; color: #aaa; font-style: italic;">No evaluations on record.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- FOOTER -->
                        <div style="margin-top: 32px; padding-top: 12px; border-top: 1px solid #dce1e7; text-align: center;">
                            <div style="color: #aaa; font-size: 11px;">Document auto-generated by the Academic Management System.</div>
                            <div style="font-weight: bold; color: #2d6cdf; font-size: 12px; margin-top: 4px;"><span t-field="o.university_id.name"/></div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
