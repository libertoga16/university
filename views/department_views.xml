<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="university_department_view_form" model="ir.ui.view">
        <field name="name">university.department.view.form</field>
        <field name="model">university.department</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(university.action_university_professor)d" type="action" class="oe_stat_button" icon="fa-user-tie" context="{'search_default_department_id': id, 'default_department_id': id}">
                             <field name="professor_count" widget="statinfo" string="Professors"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Department Name"/></h1>
                    </div>
                    <group>
                        <group name="main_info">
                            <field name="university_id"/>
                        </group>
                        <group name="structure">
                            <field name="manager_id" widget="many2one_avatar"
                                   domain="[('department_id', '=', id)]"
                                   readonly="not id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Professors" name="professors">
                            <field name="professor_ids" mode="kanban"
                                   context="{'default_university_id': university_id, 'default_department_id': id}"
                                   options="{'quick_create': false}"
                                   readonly="not university_id">
                                <kanban class="o_uni_kanban">
                                    <field name="id"/>
                                    <field name="name"/>
                                    <field name="image_128"/>
                                    <templates>
                                        <t t-name="card">
                                            <div class="o_uni_person_card">
                                                <div class="o_uni_avatar_wrapper">
                                                    <img t-if="record.image_128.raw_value"
                                                         t-attf-src="/web/image/university.professor/#{record.id.raw_value}/image_128"
                                                         alt="Professor"/>
                                                    <div t-else="" class="o_uni_avatar_placeholder">
                                                        <i class="fa fa-user" title="Professor"/>
                                                    </div>
                                                </div>
                                                <div class="o_uni_person_name"><field name="name"/></div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="university_department_view_list" model="ir.ui.view">
        <field name="name">university.department.view.list</field>
        <field name="model">university.department</field>
        <field name="arch" type="xml">
            <list sample="1">
                <field name="name" decoration-bf="1"/>
                <field name="university_id"/>
                <field name="manager_id" widget="many2one_avatar"/>
                <field name="professor_count" sum="Total Professors"/>
            </list>
        </field>
    </record>

    <record id="university_department_view_kanban" model="ir.ui.view">
        <field name="name">university.department.view.kanban</field>
        <field name="model">university.department</field>
        <field name="arch" type="xml">
            <kanban class="o_uni_kanban" sample="1">
                <field name="name"/>
                <field name="university_id"/>
                <field name="manager_id"/>
                <field name="professor_count"/>
                <templates>
                    <t t-name="card">
                        <div class="o_uni_dept_card">
                            <!-- Icon + name row -->
                            <div class="d-flex align-items-start gap-3 mb-3">
                                <div class="o_uni_dept_icon">
                                    <i class="fa fa-building" title="Department"/>
                                </div>
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="o_uni_dept_name text-truncate">
                                        <field name="name"/>
                                    </div>
                                    <div class="o_uni_dept_uni text-truncate">
                                        <field name="university_id"/>
                                    </div>
                                </div>
                            </div>
                            <!-- Footer: manager + professor count -->
                            <footer class="d-flex justify-content-between align-items-center pt-2 border-top">
                                <field name="manager_id" widget="many2one_avatar"/>
                                <span class="o_uni_dept_prof_badge">
                                    <i class="fa fa-user-tie me-1"/>
                                    <field name="professor_count"/> Prof.
                                </span>
                            </footer>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="university_department_view_search" model="ir.ui.view">
        <field name="name">university.department.view.search</field>
        <field name="model">university.department</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="university_id"/>
                <field name="manager_id"/>
                <separator/>
                <filter string="University" name="group_university" context="{'group_by':'university_id'}"/>
                <filter string="Manager" name="group_manager" context="{'group_by':'manager_id'}"/>
            </search>
        </field>
    </record>
</odoo>