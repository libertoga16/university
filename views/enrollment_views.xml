<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORM VIEW -->
    <record id="university_enrollment_view_form" model="ir.ui.view">
        <field name="name">university.enrollment.view.form</field>
        <field name="model">university.enrollment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="code" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group name="org_info">
                            <field name="university_id"/>
                            <field name="student_id"
                                   domain="[('university_id', '=', university_id)]"
                                   readonly="not university_id"/>
                        </group>
                        <group name="main_info">
                            <field name="subject_id"
                                   domain="[('university_id', '=', university_id)]"
                                   readonly="not university_id"/>
                            <field name="professor_id" widget="many2one_avatar"
                                   domain="[('university_id', '=', university_id), ('subject_ids', 'in', [subject_id])]"
                                   readonly="not subject_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Grades" name="grades">
                            <field name="grade_ids">
                                <list editable="bottom"
                                      decoration-danger="score &lt; 5"
                                      decoration-success="score &gt;= 5">
                                    <field name="date"/>
                                    <field name="score"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="university_enrollment_view_list" model="ir.ui.view">
        <field name="name">university.enrollment.view.list</field>
        <field name="model">university.enrollment</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="student_id"/>
                <field name="subject_id"/>
                <field name="university_id"/>
                <field name="professor_id" widget="many2one_avatar" optional="show"/>
            </list>
        </field>
    </record>
    
    <!-- KANBAN VIEW -->
    <record id="university_enrollment_view_kanban" model="ir.ui.view">
        <field name="name">university.enrollment.view.kanban</field>
        <field name="model">university.enrollment</field>
        <field name="arch" type="xml">
            <kanban class="o_uni_kanban" sample="1">
                <field name="code"/>
                <field name="student_id"/>
                <field name="subject_id"/>
                <field name="professor_id"/>
                <templates>
                    <t t-name="card">
                        <div class="o_uni_enrollment_card">
                            <!-- Enrollment code — monospace, brand colored -->
                            <div class="o_uni_enrollment_code mb-2">
                                <field name="code"/>
                            </div>
                            <!-- Student and subject -->
                            <div class="o_uni_enrollment_meta">
                                <i class="fa fa-user me-1 text-muted small"/>
                                <field name="student_id"/>
                            </div>
                            <div class="o_uni_enrollment_sub mt-1">
                                <i class="fa fa-book me-1 text-muted small"/>
                                <field name="subject_id"/>
                            </div>
                            <!-- Professor avatar footer -->
                            <footer class="d-flex justify-content-end mt-2 pt-2 border-top">
                                <field name="professor_id" widget="many2one_avatar"/>
                            </footer>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="university_enrollment_view_search" model="ir.ui.view">
        <field name="name">university.enrollment.view.search</field>
        <field name="model">university.enrollment</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="student_id"/>
                <field name="university_id"/>
                <!-- professor_id and subject_id required for smart button context filters -->
                <field name="professor_id"/>
                <field name="subject_id"/>
                <separator/>
                <filter string="University" name="group_university" context="{'group_by':'university_id'}"/>
                <filter string="Subject" name="group_subject" context="{'group_by':'subject_id'}"/>
                <filter string="Professor" name="group_professor" context="{'group_by':'professor_id'}"/>
            </search>
        </field>
    </record>


</odoo>
