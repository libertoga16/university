<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORM VIEW -->
    <record id="university_student_view_form" model="ir.ui.view">
        <field name="name">university.student.view.form</field>
        <field name="model">university.student</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_send_email" string="Send by Email" type="object" class="oe_highlight"/>
                    <button name="%(action_report_student)d" string="Print Grades" type="action"/>
                </header>
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>
                    <div class="oe_button_box" name="button_box">
                         <button name="%(university.action_university_enrollment)d" type="action" class="oe_stat_button" icon="fa-pencil-square-o" context="{'default_student_id': id, 'search_default_student_id': id}">
                            <field name="enrollment_count" widget="statinfo" string="Enrollments"/>
                        </button>
                         <button name="%(university.action_university_grade)d" type="action" class="oe_stat_button" icon="fa-list-ol" context="{'default_student_id': id, 'search_default_student_id': id}">
                            <field name="grade_count" widget="statinfo" string="Grades"/>
                        </button>
                    </div>
                    <group>
                        <group name="personal_info">
                            <field name="name"/>
                            <label for="email" string="Email"/>
                            <div class="o_row">
                                <field name="email" widget="email"/>
                                <widget name="student_send_email"/>
                            </div>
                        </group>
                        <group name="academic_info">
                            <field name="university_id"/>
                            <field name="tutor_id"
                                   domain="[('university_id', '=', university_id)]"
                                   readonly="not university_id"/>
                        </group>
                        <group name="address_info">
                             <label for="street" string="Address"/>
                            <div class="o_address_format">
                                <field name="street" placeholder="Street..." class="o_address_street"/>
                                <field name="city" placeholder="City" class="o_address_city"/>
                                <field name="state_id" class="o_address_state" placeholder="State" options="{'no_open': True}"/>
                                <field name="zip_code" placeholder="ZIP" class="o_address_zip"/>
                                <field name="country_id" placeholder="Country" class="o_address_country" options="{'no_open': True, 'no_create': True}"/>
                            </div>
                        </group>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="university_student_view_list" model="ir.ui.view">
        <field name="name">university.student.view.list</field>
        <field name="model">university.student</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="university_id"/>
                <field name="city"/>
            </list>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="university_student_view_kanban" model="ir.ui.view">
        <field name="name">university.student.view.kanban</field>
        <field name="model">university.student</field>
        <field name="arch" type="xml">
            <kanban class="o_uni_kanban" sample="1">
                <field name="id"/>
                <field name="image_128"/>
                <field name="university_id"/>
                <templates>
                    <t t-name="card">
                        <div class="o_uni_person_card">
                            <!-- Circular avatar with user fallback -->
                            <div class="o_uni_avatar_wrapper">
                                <img t-if="record.image_128.raw_value"
                                     t-attf-src="/web/image/university.student/#{record.id.raw_value}/image_128"
                                     alt="Student"/>
                                <div t-else="" class="o_uni_avatar_placeholder">
                                    <i class="fa fa-graduation-cap" title="Student"/>
                                </div>
                            </div>
                            <!-- Name and university -->
                            <div class="o_uni_person_name">
                                <field name="name"/>
                            </div>
                            <div t-if="record.university_id.raw_value" class="o_uni_person_sub">
                                <field name="university_id"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- SEARCH VIEW -->
    <record id="university_student_view_search" model="ir.ui.view">
        <field name="name">university.student.view.search</field>
        <field name="model">university.student</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="university_id"/>
                <filter string="University" name="group_university" context="{'group_by':'university_id'}"/>
            </search>
        </field>
    </record>


</odoo>
