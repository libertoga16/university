<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- LIST VIEW -->
    <record id="university_university_view_list" model="ir.ui.view">
        <field name="name">university.university.view.list</field>
        <field name="model">university.university</field>
        <field name="arch" type="xml">
            <list sample="1">
                <field name="name" decoration-bf="1"/>
                <field name="city"/>
                <field name="country_id"/>
                <field name="director_id" widget="many2one_avatar" optional="show"/>
                <field name="student_count" string="Students"/>
                <field name="professor_count" string="Professors"/>
            </list>
        </field>
    </record>

    <record id="university_university_view_form" model="ir.ui.view">
        <field name="name">university.university.form</field>
        <field name="model">university.university</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(university.action_university_student)d" type="action" class="oe_stat_button" icon="fa-users"
                                context="{'search_default_university_id': id, 'default_university_id': id}">
                            <field name="student_count" widget="statinfo" string="Students"/>
                        </button>
                        <button name="%(university.action_university_professor)d" type="action" class="oe_stat_button" icon="fa-graduation-cap"
                                context="{'search_default_university_id': id, 'default_university_id': id}">
                            <field name="professor_count" widget="statinfo" string="Professors"/>
                        </button>
                        <button name="%(university.action_university_department)d" type="action" class="oe_stat_button" icon="fa-building"
                                context="{'search_default_university_id': id, 'default_university_id': id}">
                            <field name="department_count" widget="statinfo" string="Departments"/>
                        </button>
                        <button name="%(university.action_university_enrollment)d" type="action" class="oe_stat_button" icon="fa-pencil-square-o"
                                context="{'search_default_university_id': id, 'default_university_id': id}">
                            <field name="enrollment_count" widget="statinfo" string="Enrollments"/>
                        </button>
                    </div>
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="University Name"/></h1>
                    </div>
                    <group>
                        <group name="contact_info" string="Contact">
                            <field name="email" widget="email"/>
                            <field name="director_id" widget="many2one_avatar"/>
                        </group>
                        <group name="address_info" string="Address">
                            <label for="street" string="Address"/>
                            <div class="o_address_format">
                                <field name="street" placeholder="Street..." class="o_address_street"/>
                                <field name="city" placeholder="City" class="o_address_city"/>
                                <field name="state_id" class="o_address_state" placeholder="State" options="{'no_open': True}"/>
                                <field name="zip_code" placeholder="ZIP" class="o_address_zip"/>
                                <field name="country_id" placeholder="Country" class="o_address_country" options="{'no_open': True, 'no_create': True}"/>
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Professors" name="professors">
                            <field name="professor_ids" mode="kanban">
                                <kanban class="o_uni_kanban">
                                    <field name="id"/>
                                    <field name="image_128"/>
                                    <field name="department_id"/>
                                    <templates>
                                        <t t-name="card">
                                            <div class="o_uni_person_card">
                                                <div class="o_uni_avatar_wrapper">
                                                    <img t-if="record.image_128.raw_value"
                                                         t-attf-src="/web/image/university.professor/#{record.id.raw_value}/image_128"
                                                         alt="Professor"/>
                                                    <div t-else="" class="o_uni_avatar_placeholder">
                                                        <i class="fa fa-user" title="Professor"/>
                                                    </div>
                                                </div>
                                                <div class="o_uni_person_name"><field name="name"/></div>
                                                <div t-if="record.department_id.raw_value" class="o_uni_person_sub">
                                                    <field name="department_id"/>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                        <page string="Students" name="students">
                            <field name="student_ids" mode="kanban">
                                <kanban class="o_uni_kanban">
                                    <field name="id"/>
                                    <field name="image_128"/>
                                    <field name="tutor_id"/>
                                    <templates>
                                        <t t-name="card">
                                            <div class="o_uni_person_card">
                                                <div class="o_uni_avatar_wrapper">
                                                    <img t-if="record.image_128.raw_value"
                                                         t-attf-src="/web/image/university.student/#{record.id.raw_value}/image_128"
                                                         alt="Student"/>
                                                    <div t-else="" class="o_uni_avatar_placeholder">
                                                        <i class="fa fa-user-graduate" title="Student"/>
                                                    </div>
                                                </div>
                                                <div class="o_uni_person_name"><field name="name"/></div>
                                                <div t-if="record.tutor_id.raw_value" class="o_uni_person_sub">
                                                    <field name="tutor_id"/>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="university_university_view_search" model="ir.ui.view">
        <field name="name">university.university.view.search</field>
        <field name="model">university.university</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="city"/>
                <field name="country_id"/>
                <field name="director_id"/>
                <separator/>
                <filter string="Country" name="group_country" context="{'group_by': 'country_id'}"/>
            </search>
        </field>
    </record>

    <record id="university_university_view_kanban" model="ir.ui.view">
        <field name="name">university.university.view.kanban</field>
        <field name="model">university.university</field>
        <field name="arch" type="xml">
            <kanban class="o_uni_kanban o_uni_kanban_university" sample="1">
                <field name="id"/>
                <field name="image_128"/>
                <field name="city"/>
                <templates>
                    <t t-name="card">
                        <!-- Hero image section -->
                        <div class="o_uni_uni_hero">
                            <img t-if="record.image_128.raw_value"
                                 t-attf-src="/web/image/university.university/#{record.id.raw_value}/image_128"
                                 class="o_uni_uni_hero_img"
                                 alt="University"/>
                            <i t-else="" class="fa fa-university o_uni_uni_hero_fallback" title="University"/>
                        </div>
                        <!-- Card body -->
                        <div class="o_uni_uni_body">
                            <div class="o_uni_uni_name">
                                <field name="name"/>
                            </div>
                            <div t-if="record.city.raw_value" class="o_uni_uni_city">
                                <i class="fa fa-map-marker"/>
                                <field name="city"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>