<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="university_university_view_form" model="ir.ui.view">
        <field name="name">university.university.form</field>
        <field name="model">university.university</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(university.action_university_student)d" type="action" class="oe_stat_button" icon="fa-users">
                            <field name="student_count" widget="statinfo" string="Students"/>
                        </button>
                    </div>
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="University Name"/></h1>
                    </div>
                    <group>
                        <field name="email" widget="email"/>
                        <field name="director_id" widget="many2one_avatar" domain="['|', ('university_id', '=', id), ('university_id', '=', False)]"/>
                    </group>
                    <notebook>
                        <page string="Professors" name="professors">
                            <field name="professor_ids" mode="kanban">
                                <kanban>
                                    <field name="id"/>
                                    <field name="image_128"/>
                                    <templates>
                                        <t t-name="card">
                                            <div class="d-flex align-items-center">
                                                <img t-if="record.image_128.raw_value"
                                                     t-attf-src="/web/image/university.professor/#{record.id.raw_value}/image_128"
                                                     class="o_image_64_max rounded shadow-sm me-3"
                                                     alt="Professor"/>
                                                <div t-else="" class="o_image_64_max rounded shadow-sm bg-light d-flex align-items-center justify-content-center me-3" style="width:64px; height:64px;">
                                                    <i class="fa fa-user fa-2x text-muted"/>
                                                </div>
                                                <div class="d-flex flex-column">
                                                    <field name="name" class="fw-bolder"/>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="university_university_view_kanban" model="ir.ui.view">
        <field name="name">university.university.view.kanban</field>
        <field name="model">university.university</field>
        <field name="arch" type="xml">
            <kanban sample="1">
                <field name="id"/>
                <field name="image_128"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex align-items-center">
                            <div class="me-3">
                                <img t-if="record.image_128.raw_value"
                                     t-attf-src="/web/image/university.university/#{record.id.raw_value}/image_128"
                                     class="o_image_64_max rounded shadow-sm"
                                     style="width: 64px; height: 64px; object-fit: cover;"/>
                                <div t-else="" class="o_image_64_max rounded shadow-sm bg-light d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                                    <i class="fa fa-university fa-2x text-muted"/>
                                </div>
                            </div>
                            <div class="d-flex flex-column">
                                <field name="name" class="fw-bolder fs-5"/>
                                <span class="text-muted"><field name="city"/></span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>