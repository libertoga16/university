<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inject 'Grades' tile into the portal homepage (My Account) only for students -->
    <template id="portal_my_home_university" name="Show Grades" inherit_id="portal.portal_my_home" priority="40">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-if="is_student">
                <a href="/my/grades"
                   class="o_uni_portal_tile list-group-item list-group-item-action d-flex align-items-center justify-content-between p-3 border-0 mb-2 rounded mt-2">
                    <div class="d-flex align-items-center gap-3">
                        <div class="o_uni_tile_icon_wrap">
                            <i class="fa fa-graduation-cap" title="Grades"/>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">Grades</h5>
                            <div class="small text-muted">Academic history and scores</div>
                        </div>
                    </div>
                    <span class="badge rounded-pill bg-primary" t-out="grade_count or 0"/>
                </a>
            </t>
        </xpath>
    </template>

    <!-- Breadcrumb entry for the grades page -->
    <template id="portal_my_home_menu_university" name="Portal layout : Grades menu" inherit_id="portal.portal_breadcrumbs" priority="40">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'grade'" class="breadcrumb-item active">Grades</li>
        </xpath>
    </template>

    <!-- /my/grades — Student grade history, paginated and sortable -->
    <template id="portal_my_grades" name="My Grades">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">My Grades</t>
            </t>

            <!-- Empty state when no grades exist -->
            <div t-if="not grades" class="o_uni_grades_empty">
                <i class="fa fa-inbox"/>
                <p>No grades recorded yet.</p>
            </div>

            <!-- Grades table -->
            <div t-if="grades" class="o_uni_grades_card card mt-3">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table o_uni_grades_table mb-0">
                            <thead>
                                <tr>
                                    <th><i class="fa fa-calendar me-2"/>Date</th>
                                    <th><i class="fa fa-book me-2"/>Subject</th>
                                    <th><i class="fa fa-user me-2"/>Professor</th>
                                    <th class="text-end"><i class="fa fa-star me-2"/>Score</th>
                                    <th class="text-center">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="grades" t-as="grade">
                                    <tr>
                                        <td>
                                            <span class="text-muted small" t-field="grade.date"/>
                                        </td>
                                        <td>
                                            <span class="o_uni_grade_subject" t-field="grade.enrollment_id.subject_id.name"/>
                                        </td>
                                        <td>
                                            <span t-if="grade.enrollment_id.professor_id" class="text-muted" t-field="grade.enrollment_id.professor_id.name"/>
                                            <span t-else="" class="text-muted fst-italic small">—</span>
                                        </td>
                                        <td class="text-end">
                                            <!-- CSS class drives color; Python ternary valid in server-side QWeb -->
                                            <span t-attf-class="o_uni_grade_score_val {{ 'text-success' if grade.score >= 5 else 'text-danger' }}"
                                                  t-field="grade.score"
                                                  t-options='{"widget": "float", "precision": 1}'/>
                                        </td>
                                        <td class="text-center">
                                            <t t-if="grade.score &gt;= 9">
                                                <span class="o_uni_badge distinction">
                                                    <i class="fa fa-star"/>Distinction
                                                </span>
                                            </t>
                                            <t t-elif="grade.score &gt;= 5">
                                                <span class="o_uni_badge pass">
                                                    <i class="fa fa-check"/>Pass
                                                </span>
                                            </t>
                                            <t t-else="">
                                                <span class="o_uni_badge fail">
                                                    <i class="fa fa-times"/>Fail
                                                </span>
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Pagination -->
            <div t-if="pager" class="o_portal_pager text-center mt-4">
                <t t-call="portal.pager"/>
            </div>
        </t>
    </template>
</odoo>
