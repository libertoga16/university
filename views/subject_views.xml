<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORM VIEW -->
    <record id="university_subject_view_form" model="ir.ui.view">
        <field name="name">university.subject.view.form</field>
        <field name="model">university.subject</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                         <button name="%(university.action_university_enrollment)d" type="action" class="oe_stat_button" icon="fa-pencil-square-o" context="{'default_subject_id': id, 'search_default_subject_id': id}">
                            <field name="enrollment_count" widget="statinfo" string="Enrollments"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Subject Name"/></h1>
                    </div>
                    <group>
                        <group name="main_info">
                            <field name="code"/>
                        </group>
                        <group name="org_info">
                            <field name="department_id"/>
                            <field name="university_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Professors" name="professors">
                            <field name="professor_ids"
                                   domain="[('university_id', '=', university_id)]"
                                   readonly="not department_id"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="university_subject_view_list" model="ir.ui.view">
        <field name="name">university.subject.view.list</field>
        <field name="model">university.subject</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="department_id"/>
                <field name="university_id"/>
            </list>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="university_subject_view_kanban" model="ir.ui.view">
        <field name="name">university.subject.view.kanban</field>
        <field name="model">university.subject</field>
        <field name="arch" type="xml">
            <kanban class="o_uni_kanban" sample="1">
                <field name="name"/>
                <field name="code"/>
                <field name="university_id"/>
                <templates>
                    <t t-name="card">
                        <div class="o_uni_subject_card">
                            <!-- Icon + code + name row -->
                            <div class="d-flex align-items-start gap-3 mb-3">
                                <div class="o_uni_subject_icon">
                                    <i class="fa fa-book" title="Subject"/>
                                </div>
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="o_uni_subject_name text-truncate">
                                        <field name="name"/>
                                    </div>
                                    <span class="o_uni_subject_code mt-1">
                                        <field name="code"/>
                                    </span>
                                </div>
                            </div>
                            <!-- Footer: university -->
                            <footer class="d-flex align-items-center gap-2 text-truncate pt-2 border-top">
                                <i class="fa fa-university text-muted small"/>
                                <span class="text-muted small text-truncate">
                                    <field name="university_id"/>
                                </span>
                            </footer>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

     <!-- SEARCH VIEW -->
     <record id="university_subject_view_search" model="ir.ui.view">
        <field name="name">university.subject.view.search</field>
        <field name="model">university.subject</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="department_id"/>
                <field name="university_id"/>
                <filter string="University" name="group_university" context="{'group_by':'university_id'}"/>
                <filter string="Department" name="group_department" context="{'group_by':'department_id'}"/>
            </search>
        </field>
    </record>


</odoo>
