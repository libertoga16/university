<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORM VIEW -->
    <record id="university_professor_view_form" model="ir.ui.view">
        <field name="name">university.professor.view.form</field>
        <field name="model">university.professor</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <!-- Avatar image editable from top-right -->
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(university.action_university_enrollment)d" type="action" class="oe_stat_button" icon="fa-pencil-square-o" context="{'default_professor_id': id, 'search_default_professor_id': id}">
                            <field name="enrollment_count" widget="statinfo" string="Enrollments"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Professor Name"/></h1>
                    </div>
                    <!-- Main academic and contact information -->
                    <group>
                        <group name="main_info">
                            <field name="email" widget="email"/>
                            <field name="university_id"/>
                        </group>
                        <group name="deps">
                            <field name="department_id"
                                  domain="[('university_id', '=', university_id)]"
                                  readonly="not university_id"/>
                        </group>
                    </group>

                    <!-- Subject assignments and additional details -->
                    <notebook>
                        <page string="Subjects" name="subjects">
                            <field name="subject_ids"
                                   domain="[('university_id', '=', university_id)]"
                                   context="{'default_department_id': department_id, 'default_university_id': university_id}"
                                   readonly="not university_id"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="university_professor_view_list" model="ir.ui.view">
        <field name="name">university.professor.view.list</field>
        <field name="model">university.professor</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="university_id"/>
                <field name="department_id"/>
            </list>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="university_professor_view_kanban" model="ir.ui.view">
        <field name="name">university.professor.view.kanban</field>
        <field name="model">university.professor</field>
        <field name="arch" type="xml">
            <kanban class="o_uni_kanban" sample="1">
                <field name="id"/>
                <field name="image_128"/>
                <field name="department_id"/>
                <templates>
                    <t t-name="card">
                        <div class="o_uni_person_card">
                            <!-- Circular avatar with user-fa fallback -->
                            <div class="o_uni_avatar_wrapper">
                                <img t-if="record.image_128.raw_value"
                                     t-attf-src="/web/image/university.professor/#{record.id.raw_value}/image_128"
                                     alt="Professor"/>
                                <div t-else="" class="o_uni_avatar_placeholder">
                                    <i class="fa fa-user" title="Professor"/>
                                </div>
                            </div>
                            <!-- Name and department -->
                            <div class="o_uni_person_name">
                                <field name="name"/>
                            </div>
                            <div t-if="record.department_id.raw_value" class="o_uni_person_sub">
                                <field name="department_id"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- SEARCH VIEW -->
    <record id="university_professor_view_search" model="ir.ui.view">
        <field name="name">university.professor.view.search</field>
        <field name="model">university.professor</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="university_id"/>
                <field name="department_id"/>
                <filter string="University" name="group_university" context="{'group_by':'university_id'}"/>
            </search>
        </field>
    </record>


</odoo>
