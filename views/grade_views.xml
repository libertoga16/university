<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="university_grade_view_form" model="ir.ui.view">
        <field name="name">university.grade.view.form</field>
        <field name="model">university.grade</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group name="main_info">
                            <field name="enrollment_id"/>
                            <field name="student_id" readonly="1"/>
                        </group>
                        <group name="score_info">
                            <field name="date"/>
                            <field name="score"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

   
    <record id="university_grade_view_list" model="ir.ui.view">
        <field name="name">university.grade.view.list</field>
        <field name="model">university.grade</field>
        <field name="arch" type="xml">
            <list editable="bottom" decoration-danger="score &lt; 5" decoration-success="score &gt;= 5">
                <field name="date"/>
                <field name="enrollment_id"/>
                <field name="student_id"/>
                <field name="score"/>
            </list>
        </field>
    </record>


    <record id="university_grade_view_kanban" model="ir.ui.view">
        <field name="name">university.grade.view.kanban</field>
        <field name="model">university.grade</field>
        <field name="arch" type="xml">
            <kanban class="o_uni_kanban" sample="1">
                <field name="id"/>
                <field name="enrollment_id"/>
                <field name="student_id"/>
                <field name="score"/>
                <templates>
                    <t t-name="card">
                        <div class="o_uni_grade_card">
                            <div class="d-flex align-items-start justify-content-between">
                                <!-- Score: large, color-coded. JS ternary required in OWL kanban context -->
                                <div>
                                    <div t-attf-class="o_uni_grade_score {{ record.score.raw_value >= 9 ? 'merit' : (record.score.raw_value >= 5 ? 'pass' : 'fail') }}">
                                        <!-- t-options forbidden in kanban (OWL); use plain field — precision set on model -->
                                        <field name="score"/>
                                    </div>
                                    <div class="o_uni_grade_label">
                                        <t t-if="record.score.raw_value >= 9">Distinction</t>
                                        <t t-elif="record.score.raw_value >= 5">Pass</t>
                                        <t t-else="">Fail</t>
                                    </div>
                                </div>
                                <!-- Enrollment code: monospace via SCSS class, no inline style -->
                                <span class="o_uni_subject_code">
                                    <field name="enrollment_id"/>
                                </span>
                            </div>
                            <!-- Student footer -->
                            <footer class="d-flex align-items-center gap-2 text-muted small mt-2 pt-2 border-top">
                                <i class="fa fa-user"/>
                                <field name="student_id"/>
                            </footer>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="university_grade_view_search" model="ir.ui.view">
        <field name="name">university.grade.view.search</field>
        <field name="model">university.grade</field>
        <field name="arch" type="xml">
            <search>
                <field name="enrollment_id"/>
                <field name="student_id"/>
            </search>
        </field>
    </record>


</odoo>
