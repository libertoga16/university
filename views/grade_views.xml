<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORM VIEW -->
    <record id="university_grade_view_form" model="ir.ui.view">
        <field name="name">university.grade.view.form</field>
        <field name="model">university.grade</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group name="main_info">
                            <field name="enrollment_id"/>
                            <field name="student_id" readonly="1"/>
                        </group>
                        <group name="score_info">
                            <field name="score"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="university_grade_view_list" model="ir.ui.view">
        <field name="name">university.grade.view.list</field>
        <field name="model">university.grade</field>
        <field name="arch" type="xml">
            <list editable="bottom" decoration-danger="score &lt; 5" decoration-success="score &gt;= 5">
                <field name="enrollment_id"/>
                <field name="student_id"/>
                <field name="score"/>
            </list>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="university_grade_view_kanban" model="ir.ui.view">
        <field name="name">university.grade.view.kanban</field>
        <field name="model">university.grade</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="id"/>
                <field name="enrollment_id"/>
                <field name="student_id"/>
                <field name="score"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex mb-2" style="justify-content: space-between;">
                            <field name="enrollment_id" class="fw-bolder fs-5"/>
                        </div>
                        <footer>
                            <div class="d-flex justify-content-between text-muted w-100">
                                <div><field name="student_id"/></div>
                                <div><field name="score"/></div>
                            </div>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="university_grade_view_search" model="ir.ui.view">
        <field name="name">university.grade.view.search</field>
        <field name="model">university.grade</field>
        <field name="arch" type="xml">
            <search>
                <field name="enrollment_id"/>
                <field name="student_id"/>
            </search>
        </field>
    </record>


</odoo>
