#. module: university
#: model:mail.template,body_html:university.email_template_student_report
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"                        Dear <t t-out=\"object.name\"/>,\n"
"                        <br/><br/>\n"
"                        Please find attached your latest <strong>Academic Report</strong> issued by <strong t-out=\"object.university_id.name\"/>.\n"
"                        <br/>\n"
"                        This document details the subjects you have completed, the professors in charge, and the grades obtained to date.\n"
"                        <br/><br/>\n"
"                        If you have any questions regarding the information presented, please contact your university's administration office.\n"
"                        <br/><br/>\n"
"                        Kind regards,\n"
"                        <br/>\n"
"                        <strong>Academic Administration</strong>\n"
"                    </p>\n"
"                </div>\n"
"            "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"                        Estimado/a <t t-out=\"object.name\"/>,\n"
"                        <br/><br/>\n"
"                        Adjunto encontrarás tu último <strong>Informe Académico</strong> emitido por <strong t-out=\"object.university_id.name\"/>.\n"
"                        <br/>\n"
"                        Este documento detalla las asignaturas que has completado, los profesores responsables y las notas obtenidas hasta la fecha.\n"
"                        <br/><br/>\n"
"                        Si tienes alguna pregunta sobre la información presentada, por favor contacta con la oficina de administración de tu universidad.\n"
"                        <br/><br/>\n"
"                        Un cordial saludo,\n"
"                        <br/>\n"
"                        <strong>Administración Académica</strong>\n"
"                    </p>\n"
"                </div>\n"
"            "

