<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="email_template_student_report" model="mail.template">
            <field name="name">Student Report: Send by Email</field>
            <field name="model_id" ref="university.model_university_student"/>
            <field name="subject">Academic Report - {{ object.name }}</field>
            <field name="email_from">{{ (object.university_id.email or user.email_formatted) }}</field>
            <field name="email_to">{{ object.email }}</field>
            <field name="description">Sent to students with their academic grades</field>
           
            <field name="report_template_ids" eval="[(6, 0, [ref('university.action_report_student')])]"/>

            <field name="body_html" type="html">
                <div>
                    <p>
                        Dear <t t-out="object.name"/>,
                        <br/><br/>
                        Please find attached your latest <strong>Academic Report</strong> issued by <strong t-out="object.university_id.name"/>.
                        <br/>
                        This document details the subjects you have completed, the professors in charge, and the grades obtained to date.
                        <br/><br/>
                        If you have any questions regarding the information presented, please contact your university's administration office.
                        <br/><br/>
                        Kind regards,
                        <br/>
                        <strong>Academic Administration</strong>
                    </p>
                </div>
            </field>
        </record>
    </data>
</odoo>